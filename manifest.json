{
  "manifest_version": 3,
  "name": "NeoAmp — Music Visualizer",
  "version": "0.3.0",
  "description": "NeoAmp overlays a Winamp-style player + MilkDrop (Butterchurn) visualizations on YouTube Music, including hand-authored recreations of classic Windows Media Player visualizers (Alchemy / Battery / Ambience).",
  "permissions": ["storage", "tabCapture", "offscreen", "activeTab", "contextMenus"],
  "host_permissions": ["https://music.youtube.com/*"],
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_title": "NeoAmp — start/stop the player + EQ (captures this tab's audio)",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "sw.js" },
  "commands": {
    "toggle-eq": {
      "suggested_key": { "default": "Ctrl+Shift+E", "mac": "Command+Shift+E" },
      "description": "Open / close the NeoAmp player"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["skins.js", "content.js", "wsz.js", "winamp.js"],
      "css": ["overlay.css", "winamp.css"],
      "run_at": "document_idle"
    }
  ],
  "sandbox": {
    "pages": ["viz.html"]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts allow-popups allow-modals allow-forms; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'; child-src 'self'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "viz.html",
        "viz.js",
        "presets/kit.js",
        "presets/dance.js",
        "presets/alchemy.js",
        "presets/ambience.js",
        "presets/battery.js",
        "fonts/VT323-Regular.ttf",
        "vendor/butterchurn.min.js",
        "vendor/butterchurnPresets.min.js",
        "vendor/butterchurnPresetsExtra.min.js",
        "vendor/butterchurnPresetsExtra2.min.js",
        "vendor/skins/base-2.91.wsz",
        "vendor/skins/topazamp.wsz",
        "vendor/skins/sony-esprit.wsz",
        "vendor/skins/nucleo-nlog.wsz",
        "vendor/skins/winamp3-classified.wsz",
        "vendor/skins/winamp5-classified.wsz",
        "vendor/skins/bento-classified.wsz"
      ],
      "matches": ["https://music.youtube.com/*"]
    }
  ]
}
